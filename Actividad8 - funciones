# Función con parámetros para mostrar los datos del estudiante
def mostrar_estudiante(nombre, curso):
    print("Estudiante registrado:")
    print("Nombre:", nombre)
    print("Curso:", curso)
    print("-------------------")
# Función sin parámetros para mostrar el mensaje final
def mensaje_final():
    print("Fin del programa")
# Preguntar cuántos estudiantes se desean ingresar
cantidad = int(input("¿Cuántos estudiantes desea ingresar?: "))
contador = 1
# Ciclo while para registrar varios estudiantes
while contador <= cantidad:
    print("\nRegistro del estudiante", contador)
    nombre = input("Ingrese el nombre del estudiante: ")
    curso = input("Ingrese el curso del estudiante: ")
    mostrar_estudiante(nombre, curso)
    contador += 1
# Llamar a la función final
mensaje_final()
